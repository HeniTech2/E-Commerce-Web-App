generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  cartData  Json     @default("{}")
  wishlist  String[] @default([])
  orders    Order[]
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  image       String[]
  category    String
  subCategory String
  sizes       String[]
  bestseller  Boolean  @default(false)
  stock       Int      @default(99)
  date        BigInt
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  items         Json
  amount        Float
  address       Json
  status        String   @default("Order Placed")
  paymentMethod String
  payment       Boolean  @default(false)
  txRef         String?
  date          BigInt
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String?
  subtitle  String?
  body      String?
  image     String?
  link      String?
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model NavItem {
  id        String   @id @default(uuid())
  label     String
  href      String
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
}

model FooterSection {
  id        String      @id @default(uuid())
  title     String
  order     Int         @default(0)
  links     FooterLink[]
  createdAt DateTime    @default(now())
}

model FooterLink {
  id        String        @id @default(uuid())
  label     String
  href      String
  order     Int           @default(0)
  sectionId String
  section   FooterSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model PageSection {
  id         String   @id @default(uuid())
  type       String   @default("text")
  title      String?
  body       String?
  imageUrl   String?
  bgColor    String?
  bgImageUrl String?
  position   String   @default("center")
  order      Int      @default(0)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
}